---
interface Props {
  icon?: string;
  title?: string;
  message?: string;
  showHomeLink?: boolean;
}

const { 
  icon = "fas fa-paint-roller", 
  title = "Under Construction", 
  message = "зҸҫеңЁжә–еӮҷдёӯгҒ§гҒҷпјҒе…¬й–ӢгҒҫгҒ§гӮӮгҒҶе°‘гҒ—гҒҠеҫ…гҒЎгҒҸгҒ гҒ•гҒ„рҹҗҫ",
  showHomeLink = true
} = Astro.props;
---

<div class="placeholder-page">
  <i class={icon}></i>
  <h2>{title}</h2>
  <p set:html={message}></p>
  {showHomeLink && (
    <a href="/" class="gallery-link" style="margin-top: 1.5rem;">
      <i class="fas fa-home" style="font-size: 0.85em; margin-right: 0.2rem;"></i> гғҲгғғгғ—гғҡгғјгӮёгҒёжҲ»гӮӢ &rarr;
    </a>
  )}
</div>
