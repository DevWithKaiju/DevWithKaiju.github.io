---
interface Props {
  icon?: string;
  title?: string;
  message?: string;
  showHomeLink?: boolean;
}

const { 
  icon = "fas fa-paint-roller", 
  title = "Under Construction", 
  message = "現在準備中です！公開までもう少しお待ちください🐾",
  showHomeLink = true
} = Astro.props;
---

<div class="placeholder-page">
  <i class={icon}></i>
  <h2>{title}</h2>
  <p set:html={message}></p>
  {showHomeLink && (
    <a href="/" class="gallery-link placeholder-link" style="margin-top: 1.5rem;">
      <i class="fas fa-home home-icon" style="font-size: 0.85em; margin-right: 0.2rem;"></i> トップページへ戻る &rarr;
    </a>
  )}
</div>

<style>
  .placeholder-link .home-icon {
    color: var(--accent-color);
    transition: color 0.3s ease;
  }
  .placeholder-link:hover .home-icon {
    color: var(--primary-color);
  }
</style>
