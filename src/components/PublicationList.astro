---
import type { CollectionEntry } from 'astro:content';

interface Props {
  publications: CollectionEntry<'publications'>[];
}

const { publications } = Astro.props;
---

<ul class="clean-list" style="display: flex; flex-direction: column; gap: 0.8rem;">
  {publications.map((pub) => (
    <li style="align-items: flex-start; gap: 0.5rem; border-bottom: 1px dashed var(--global-border-color); padding-bottom: 0.8rem;">
      <span style="color: var(--primary-color); font-weight: 500; min-width: 50px; margin-top: 2px;">{pub.data.date.getFullYear()}</span>
      <span style="line-height: 1.5;">
        <strong><a href={pub.data.paperurl || '#'} target="_blank" rel="noopener noreferrer" class="hover-link">{pub.data.title}</a></strong><br />
        {pub.data.authors && <><span class="text-light">{pub.data.authors}</span><br /></>}
        {pub.data.venue && <span style="color: var(--primary-color); font-weight: 500;"><em>{pub.data.venue}</em></span>}
      </span>
    </li>
  ))}
</ul>
